<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:SupremeCommanderEditor.App.Controls"
        x:Class="SupremeCommanderEditor.App.Views.ColorPickerDialog"
        Width="520" Height="560"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="#1E1E22"
        Title="Pick color">

    <DockPanel Margin="14">
        <TextBlock x:Name="HeaderText" DockPanel.Dock="Top" FontWeight="Bold" Foreground="#EEE" FontSize="14" Margin="0,0,0,10"/>

        <Border DockPanel.Dock="Bottom" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <Button Content="Cancel" Click="OnCancel" Padding="16,6" FontSize="12"/>
                <Button Content="OK" Click="OnOk" Padding="20,6" FontSize="12" Background="#3060A0" Foreground="White"/>
            </StackPanel>
        </Border>

        <!-- Preview swatch + hex + RGB. Updated in code-behind on every color change. -->
        <Border DockPanel.Dock="Bottom" Margin="0,10,0,0" Padding="8" Background="#28282C" CornerRadius="3">
            <Grid ColumnDefinitions="60,*" RowDefinitions="Auto,Auto" RowSpacing="6">
                <Border x:Name="PreviewSwatch" Grid.RowSpan="2" Width="48" Height="48" CornerRadius="3"
                        BorderBrush="#666" BorderThickness="1"/>
                <TextBlock x:Name="HexText" Grid.Column="1" Grid.Row="0" Foreground="#CCC" FontSize="11"/>
                <TextBlock x:Name="RgbText" Grid.Column="1" Grid.Row="1" Foreground="#999" FontSize="10"/>
            </Grid>
        </Border>

        <!-- Vertical brightness (V) slider on the right side -->
        <Border DockPanel.Dock="Right" Margin="14,0,0,0" Padding="6,0">
            <StackPanel Spacing="6" HorizontalAlignment="Center">
                <TextBlock Text="V" Foreground="#AAA" FontSize="11" HorizontalAlignment="Center"/>
                <Slider x:Name="BrightnessSlider" Orientation="Vertical" Minimum="0" Maximum="1" Value="1" Height="340"
                        ValueChanged="OnBrightnessChanged"/>
                <TextBlock x:Name="BrightnessText" Foreground="#888" FontSize="10" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- The HSV color wheel takes the rest of the center area -->
        <controls:ColorWheelControl x:Name="Wheel"
                                     MinWidth="340" MinHeight="340"/>
    </DockPanel>
</Window>
