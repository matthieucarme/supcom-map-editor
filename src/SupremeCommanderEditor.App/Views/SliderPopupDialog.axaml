<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:v="using:SupremeCommanderEditor.App.Views"
        x:Class="SupremeCommanderEditor.App.Views.SliderPopupDialog"
        Width="380" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="#1E1E22"
        Title="Edit value">

    <DockPanel Margin="16">
        <TextBlock x:Name="HeaderText" DockPanel.Dock="Top" FontWeight="Bold" Foreground="#EEE" FontSize="14" Margin="0,0,0,12"/>

        <Border DockPanel.Dock="Bottom" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <Button Content="Cancel" Click="OnCancel" Padding="16,6" FontSize="12"/>
                <Button Content="OK" Click="OnOk" Padding="20,6" FontSize="12" Background="#3060A0" Foreground="White"/>
            </StackPanel>
        </Border>

        <ItemsControl x:Name="ItemsHost">
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="v:SliderPopupDialog+SliderItem">
                    <Grid ColumnDefinitions="60,*,56" Margin="0,2,0,6">
                        <TextBlock Text="{Binding Label}" FontSize="12" Foreground="#CCC" VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" Value="{Binding Value, Mode=TwoWay}" Minimum="{Binding Min}" Maximum="{Binding Max}"/>
                        <TextBox Grid.Column="2" Text="{Binding Value, Mode=TwoWay, StringFormat={}{0:F2}}"
                                 FontSize="11" Padding="4,2"/>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </DockPanel>
</Window>
