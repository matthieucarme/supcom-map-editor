<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:SupremeCommanderEditor.App.Views"
        x:Class="SupremeCommanderEditor.App.Views.MapShareDialog"
        Width="780" Height="640"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E22"
        Title="Share maps">

    <DockPanel Margin="14">
        <!-- Top: remote-path status / configure hint -->
        <Border DockPanel.Dock="Top" Background="#26262A" BorderBrush="#383840" BorderThickness="1" CornerRadius="3" Padding="10" Margin="0,0,0,10">
            <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
                <TextBlock Grid.Column="0" Grid.Row="0" Text="Remote folder:" FontWeight="Bold" Foreground="#DDD" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Grid.Column="1" Grid.Row="0" x:Name="RemotePathBox" FontSize="12" VerticalAlignment="Center"/>
                <Button Grid.Column="2" Grid.Row="0" Content="Browse…" Click="OnPickRemoteFolder" Margin="6,0,0,0" Padding="10,4" FontSize="11"/>
                <TextBlock Grid.Column="0" Grid.Row="1" Text="Your handle:" FontWeight="Bold" Foreground="#DDD" VerticalAlignment="Center" Margin="0,8,8,0"/>
                <TextBox Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="1" x:Name="HandleBox" FontSize="12" Margin="0,8,0,0"
                         Watermark="(used as author when you upload — leaves your name on each shared map)"/>
            </Grid>
        </Border>

        <!-- Bottom bar -->
        <Border DockPanel.Dock="Bottom" Margin="0,10,0,0">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock x:Name="StatusBlock" Grid.Column="0" Foreground="#999" FontSize="11" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="Close" Click="OnClose" Padding="22,6" FontSize="12"/>
            </Grid>
        </Border>

        <TabControl>
            <TabItem Header="Browse">
                <DockPanel>
                    <!-- Filter chips + Refresh -->
                    <Border DockPanel.Dock="Top" Background="#1A1A1F" Padding="0,8,0,8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <CheckBox x:Name="FilterDownloadable" Content="To download" IsChecked="True" Foreground="#DDD" Click="OnFilterChanged"/>
                            <CheckBox x:Name="FilterOutdated"     Content="Update available" IsChecked="True" Foreground="#DDD" Click="OnFilterChanged"/>
                            <CheckBox x:Name="FilterUpToDate"     Content="Up-to-date" IsChecked="False" Foreground="#DDD" Click="OnFilterChanged"/>
                            <CheckBox x:Name="FilterLocalOnly"    Content="Local only" IsChecked="False" Foreground="#DDD" Click="OnFilterChanged"/>
                            <Border Background="#3A3A3F" Width="1"/>
                            <Button Content="🔄 Refresh" Click="OnRefresh" Padding="10,4" FontSize="11"/>
                        </StackPanel>
                    </Border>

                    <ScrollViewer>
                        <ItemsControl x:Name="EntriesList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="views:MapShareEntryVm">
                                    <Border Background="#26262A" BorderBrush="#383840" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,8">
                                        <Grid ColumnDefinitions="120,*,Auto">
                                            <Image Grid.Column="0" Source="{Binding Thumbnail}" Width="110" Height="110"
                                                   Stretch="UniformToFill"
                                                   RenderOptions.BitmapInterpolationMode="HighQuality"/>
                                            <StackPanel Grid.Column="1" Margin="12,0,0,0" Spacing="2">
                                                <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14" Foreground="#EEE"/>
                                                <TextBlock Text="{Binding SubTitle}" Foreground="#AAA" FontSize="11"/>
                                                <TextBlock Text="{Binding Description}" Foreground="#CCC" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                                <TextBlock Text="{Binding ChangelogDisplay}" Foreground="#88A0C8" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"
                                                           IsVisible="{Binding HasChangelog}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="4">
                                                <TextBlock Text="{Binding StatusLabel}" Foreground="{Binding StatusColor}" FontWeight="Bold" FontSize="11" HorizontalAlignment="Right"/>
                                                <Button Content="{Binding ActionLabel}" Tag="{Binding MapId}" Click="OnEntryAction"
                                                        Padding="14,5" FontSize="12" MinWidth="100"
                                                        IsEnabled="{Binding ActionEnabled}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>

            <TabItem Header="Upload current map">
                <ScrollViewer>
                    <StackPanel Spacing="12" Margin="0,8,0,0">

                        <Border Background="#26262A" BorderBrush="#383840" BorderThickness="1" CornerRadius="4" Padding="12">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Map to upload" FontWeight="Bold" Foreground="#DDD"/>
                                <TextBlock x:Name="UploadMapNameBlock" Foreground="#CCC" FontSize="12"/>
                                <TextBlock x:Name="UploadMapDetailsBlock" Foreground="#999" FontSize="11"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#26262A" BorderBrush="#383840" BorderThickness="1" CornerRadius="4" Padding="12">
                            <StackPanel Spacing="6">
                                <TextBlock Text="Description" FontWeight="Bold" Foreground="#DDD"/>
                                <TextBlock Text="One-line summary shown to other users browsing the share." Foreground="#999" FontSize="11"/>
                                <TextBox x:Name="DescriptionBox" FontSize="13"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#26262A" BorderBrush="#383840" BorderThickness="1" CornerRadius="4" Padding="12">
                            <StackPanel Spacing="6">
                                <TextBlock Text="Changelog (optional)" FontWeight="Bold" Foreground="#DDD"/>
                                <TextBlock Text="What changed in this upload — shown to users updating an existing copy." Foreground="#999" FontSize="11"/>
                                <TextBox x:Name="ChangelogBox" FontSize="12" AcceptsReturn="True" TextWrapping="Wrap" Height="80"/>
                            </StackPanel>
                        </Border>

                        <Button Content="Upload to remote" Click="OnUpload"
                                Background="#3060A0" Foreground="White" FontWeight="Bold"
                                Padding="22,8" FontSize="13" HorizontalAlignment="Right"
                                x:Name="UploadButton"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
