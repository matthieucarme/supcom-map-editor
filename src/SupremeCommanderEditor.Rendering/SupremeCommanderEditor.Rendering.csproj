<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Pfim" Version="0.11.4" />
    <ProjectReference Include="..\SupremeCommanderEditor.Core\SupremeCommanderEditor.Core.csproj" />
    <PackageReference Include="Avalonia" Version="12.0.0" />
  </ItemGroup>

  <ItemGroup>
    <!-- Shaders are embedded in the Rendering assembly so the published exe is fully self-contained
         and has no companion files. Loaded via Assembly.GetManifestResourceStream at runtime. -->
    <EmbeddedResource Include="Shaders\**\*">
      <LogicalName>Shaders/%(RecursiveDir)%(Filename)%(Extension)</LogicalName>
    </EmbeddedResource>
    <!-- Prop and unit icons (pre-rendered 96x96 PNGs from vanilla SC meshes + albedos).
         Generated by tools/IconGenerator (run once when blueprints change), checked in,
         embedded at compile. PropIcons = decoration blueprints from env.scd. UnitIcons =
         placeable units (structures + mobile) from units.scd, keyed by unit ID (UEB1101…). -->
    <EmbeddedResource Include="PropIcons\*.png">
      <LogicalName>PropIcons/%(Filename)%(Extension)</LogicalName>
    </EmbeddedResource>
    <EmbeddedResource Include="UnitIcons\*.png">
      <LogicalName>UnitIcons/%(Filename)%(Extension)</LogicalName>
    </EmbeddedResource>
  </ItemGroup>

</Project>
